{
  "$schema": "./dev-items/Localization.schema.json",
  "general": {
    "PluginIdNotSet": {
      "JP": "プラグイン ID 未設定",
      "EN": "Plugin ID not set",
      "CN": "未设置插件 ID"
    },
    "StopIt": {
      "JP": "やめろ",
      "EN": "Stop it",
      "CN": "別這樣"
    },
    "AlreadyWaiting": {
      "JP": "読み込み待機中",
      "EN": "Already waiting for loading",
      "CN": "已在等待加载"
    },
    "RefreshPreStart": {
      "JP": "更新開始",
      "EN": "Refresh start",
      "CN": "开始刷新"
    },
    "RefreshEnd": {
      "JP": "更新終了",
      "EN": "Refresh end",
      "CN": "刷新结束"
    },
    "FailedRemove": {
      "JP": "削除失敗",
      "EN": "Failed to remove",
      "CN": "删除失败"
    }
  },
  "format": {
    "PluginFound": {
      "JP": "プラグイン発見: ${PLUGIN_ID}",
      "EN": "Plugin found: ${PLUGIN_ID}",
      "CN": "发现插件: ${PLUGIN_ID}",
      "parameters": {
        "PLUGIN_ID": {
          "type": "string"
        }
      }
    },
    "PluginNotFound": {
      "JP": "プラグイン未発見: ${PLUGIN_ID}",
      "EN": "Plugin not found: ${PLUGIN_ID}",
      "CN": "未发现插件: ${PLUGIN_ID}",
      "parameters": {
        "PLUGIN_ID": {
          "type": "string"
        }
      }
    },
    "SkipRefresh": {
      "JP": "ハッシュ値が同じため更新をスキップ(${HASH})",
      "EN": "Refresh skipped due to identical hash (${HASH})",
      "CN": "由于哈希值相同，刷新被跳过 (${HASH})",
      "parameters": {
        "HASH": {
          "type": "string"
        }
      }
    },
    "RefreshStart": {
      "JP": "更新開始(${COUNT})",
      "EN": "Refresh start(${COUNT})",
      "CN": "开始刷新(${COUNT})",
      "parameters": {
        "COUNT": {
          "type": "int"
        }
      }
    },
    "MethodStart": {
      "JP": "メソッド開始: ${METHOD_NAME}",
      "EN": "Method start: ${METHOD_NAME}",
      "CN": "方法开始: ${METHOD_NAME}",
      "parameters": {
        "METHOD_NAME": {
          "type": "string"
        }
      }
    },
    "MethodEnd": {
      "JP": "メソッド終了: ${METHOD_NAME}",
      "EN": "Method end: ${METHOD_NAME}",
      "CN": "方法结束: ${METHOD_NAME}",
      "parameters": {
        "METHOD_NAME": {
          "type": "string"
        }
      }
    },
    "MethodNotFound": {
      "JP": "メソッドなし: ${METHOD_NAME}",
      "EN": "Method not found: ${METHOD_NAME}",
      "CN": "未发现方法: ${METHOD_NAME}",
      "parameters": {
        "METHOD_NAME": {
          "type": "string"
        }
      }
    }
  },
  "config": {
    "IsEnabled": {
      "JP": "本 Mod を有効にするか",
      "EN": "Enable this mod",
      "CN": "启用此 Mod"
    },
    "PluginId": {
      "JP": "監視対象のプラグインID(package.xml: //Meta/id)",
      "EN": "Plugin ID to monitor (package.xml: //Meta/id)",
      "CN": "要监视的插件 ID (package.xml: //Meta/id)"
    },
    "DelayTime": {
      "JP": "更新検知から再読み込みまでの遅延時間",
      "EN": "Delay time from update detection to reload",
      "CN": "从更新检测到重新加载的延迟时间"
    }
  }
}
